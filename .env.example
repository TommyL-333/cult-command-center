# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PORT=3457

# ─── Data persistence (Railway Volume mount path) ─────────────────────────────
# Leave empty to use repo root (local dev). On Railway, set to /data
DATA_DIR=

# ─── Authentication ───────────────────────────────────────────────────────────
# Cloudflare Access — your team policy audience tag (from CF Access app settings)
CF_ACCESS_AUD=
# Comma-separated allowed email domains (e.g. cultcontent.cc)
ALLOWED_EMAIL_DOMAINS=cultcontent.cc
# Shared secret for GHL webhook (protects /api/webhooks/* without CF Access)
WEBHOOK_SECRET=

# ─── GHL (GoHighLevel) ───────────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_HANDLE_PERSONAL=
TIKTOK_HANDLE_BRAND=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Apify ────────────────────────────────────────────────────────────────────
APIFY_API_KEY=

# ─── OpenAI (Whisper voice transcription fallback) ───────────────────────────
OPENAI_API_KEY=

# ─── Arcads (AI video generation) ────────────────────────────────────────────
ARCADS_API_KEY=

# ─── Lark / Feishu ───────────────────────────────────────────────────────────
LARK_APP_ID=
LARK_APP_SECRET=
LARK_CALENDAR_APP_TOKEN=
LARK_CALENDAR_TABLE_ID=

# ─── Storista (TikTok Shop video publishing) ─────────────────────────────────
STORISTA_API_KEY=

# ─── Buffer ───────────────────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=

# ─── Railway (cloud server health checks) ────────────────────────────────────
RAILWAY_SERVER_URL=https://cultcontent-server-production.up.railway.app
