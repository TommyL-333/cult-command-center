# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PORT=3457

# ─── Data persistence (Railway Volume mount path) ─────────────────────────────
# Leave empty to use repo root (local dev). On Railway, set to /data
DATA_DIR=

# ─── Authentication ───────────────────────────────────────────────────────────
# Cloudflare Access — your team policy audience tag (from CF Access app settings)
CF_ACCESS_AUD=
# Comma-separated allowed email domains (e.g. cultcontent.cc)
ALLOWED_EMAIL_DOMAINS=cultcontent.cc
# Shared secret for GHL webhook (protects /api/webhooks/* without CF Access)
WEBHOOK_SECRET=

# ─── GHL (GoHighLevel) ───────────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── TikTok Developer API (Display + Content Posting) ────────────────────────
# Register at https://developers.tiktok.com
TIKTOK_HANDLE_PERSONAL=
TIKTOK_HANDLE_BRAND=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Access tokens stored in .tiktok-tokens.json["personal"] and ["brand"]

# ─── TikTok Shop Partner API ──────────────────────────────────────────────────
# Register at https://partner.tiktokshop.com → App Management → New App
# Required for: orders, products, affiliate creators, finance, webhooks
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
# OAuth redirect — must match what's set in your app on partner.tiktokshop.com
TIKTOK_SHOP_REDIRECT_URI=https://cultcontent-server-production.up.railway.app/api/tiktok-shop/callback
# Shop tokens (access_token, shop_cipher, shop_id, etc.) stored in .tiktok-tokens.json["shop"]

# ─── TikTok Ads / Business API ────────────────────────────────────────────────
# Register at https://business-api.tiktok.com/portal (requires TikTok Business Account)
# Header format: Access-Token: <token>  (no "Bearer" prefix — different from Developer API)
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

# ─── Apify ────────────────────────────────────────────────────────────────────
APIFY_API_KEY=

# ─── OpenAI (Whisper voice transcription fallback) ───────────────────────────
OPENAI_API_KEY=

# ─── Arcads (AI video generation) ────────────────────────────────────────────
ARCADS_API_KEY=

# ─── Lark / Feishu ───────────────────────────────────────────────────────────
LARK_APP_ID=
LARK_APP_SECRET=
LARK_ALERT_CHAT_ID=oc_e7fa4126968dc76eaeca1d815e706e46
LARK_CALENDAR_APP_TOKEN=
LARK_CALENDAR_TABLE_ID=

# ─── Storista (TikTok Shop video publishing) ─────────────────────────────────
STORISTA_API_KEY=

# ─── Buffer ───────────────────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=

# ─── Railway (cloud server health checks) ────────────────────────────────────
RAILWAY_SERVER_URL=https://cultcontent-server-production.up.railway.app
